# Example environment file (DO NOT COMMIT real secrets)
# Copy to .env and fill values as needed.

# Environment
ENV=dev

# Data provider selection (optional overrides)
DATA_PROVIDER_PRIMARY=yahoo
DATA_PROVIDER_SECONDARY=zerodha
DEFAULT_TIMEFRAME=1d
DEFAULT_MARKET=indian_equities
DEFAULT_UNIVERSE=nifty50

# Zerodha (Kite Connect)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
ZERODHA_REDIRECT_URL=
