# Copy to .env and fill as needed
# --- Data providers ---
DATA_PROVIDER=YAHOO
# Example: NSE symbols often require .NS on Yahoo
YAHOO_SUFFIX=.NS

# Zerodha / Kite (paper/live later)
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# --- Storage ---
DATA_DIR=./data

# --- General ---
TZ=Asia/Kolkata
